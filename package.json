{
  "name": "no-shorts",
  "version": "1.0.0",
  "description": "Chrome extension to hide YouTube Shorts.",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build:js": "esbuild src/content.ts --bundle --format=esm --target=es2021 --minify --outfile=dist/content.js",
    "build:css": "esbuild src/styles.css --minify --outfile=dist/styles.css",
    "build:assets": "node scripts/copy-assets.mjs",
    "build": "pnpm run clean && pnpm run build:js && pnpm run build:css && pnpm run build:assets",
    "watch": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "pnpm run build && cd dist && zip -r ../no-shorts-extension.zip ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.25.10",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.28.2"
}
